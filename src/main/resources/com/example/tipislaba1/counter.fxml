<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="root" prefHeight="700" prefWidth="550" spacing="12"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tipislaba1.view.counterview">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="Введите текст:" style="-fx-font-weight: bold;"/>
    <TextArea fx:id="textArea" prefRowCount="10"
              promptText="Введите текст здесь..."
              wrapText="true"
              VBox.vgrow="ALWAYS"/>

    <Button fx:id="countButton" maxWidth="Infinity" text="Посчитать">
        <font><Font size="16.0"/></font>
    </Button>

    <Label fx:id="resultLabel" text="Всего русских букв: 0">
        <font><Font name="System Bold" size="16.0"/></font>
        <style>-fx-text-fill: #0066cc; -fx-padding: 5 0 5 0;</style>
    </Label>

    <Label text="Статистика по буквам (количество):" style="-fx-font-weight: bold;"/>
    <TextArea fx:id="statisticsArea" editable="false"
              prefRowCount="7" wrapText="true"
              style="-fx-font-family: 'Monospaced'; -fx-font-size: 13px;"/>

    <Label text="Процент встречаемости:" style="-fx-font-weight: bold;"/>
    <TextArea fx:id="percentagesArea" editable="false"
              prefRowCount="7" wrapText="true"
              style="-fx-font-family: 'Monospaced'; -fx-font-size: 13px;"/>

</VBox>